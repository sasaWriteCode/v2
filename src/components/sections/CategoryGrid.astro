---
/**
 * CategoryGrid — icon link-cards into knowledge categories. Static.
 */
import { Icon } from '@/components/global/Icon';
import type { CategoryGridContent } from '@/types/sections';

type Props = CategoryGridContent;
const { heading, lede, categories } = Astro.props;
---

<div>
  {heading && <h2 class="type-heading-lg">{heading}</h2>}
  {lede && (
    <p class="type-body-md mt-2 max-w-article" style="color: var(--text-secondary)">
      {lede}
    </p>
  )}
  <ul
    class:list={[
      'grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4',
      (heading || lede) && 'mt-8',
    ]}
  >
    {categories.map((category) => (
      <li>
        <a
          href={category.href}
          class="grid h-full content-start gap-3 rounded-lg p-5"
          style="background: var(--surface-raised); border: 1px solid var(--border-subtle); box-shadow: var(--elevation-1); color: inherit; text-decoration: none"
        >
          <span
            class="inline-flex h-11 w-11 items-center justify-center rounded-full"
            style="border: 1px solid var(--border-default); color: var(--text-brand)"
          >
            <Icon name={category.icon} size={22} />
          </span>
          <span class="type-heading-sm">{category.title}</span>
          {category.description && (
            <span class="type-body-sm" style="color: var(--text-secondary)">
              {category.description}
            </span>
          )}
          {category.count && (
            <span class="type-caption" style="color: var(--text-muted)">
              {category.count}
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>
