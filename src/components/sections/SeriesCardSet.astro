---
/**
 * SeriesCardSet — the good/better/best series cards (Comfort/Plus/Signature
 * or Essential/Advanced/Signature — the taxonomy is data, see
 * _conflicts.md §1). Static, zero JS.
 */
import { Icon } from '@/components/global/Icon';
import type { SeriesCardSetContent } from '@/types/sections';

type Props = SeriesCardSetContent;
const { heading, lede, cards } = Astro.props;

const accentVar = (accent?: string) =>
  !accent || accent === 'neutral'
    ? 'var(--text-brand)'
    : `var(--accent-${accent}-text, var(--text-brand))`;
---

<div>
  {heading && <h2 class="type-heading-lg">{heading}</h2>}
  {lede && (
    <p class="type-body-md mt-2 max-w-article" style="color: var(--text-secondary)">
      {lede}
    </p>
  )}
  <ul class:list={['grid grid-cols-1 gap-5 md:grid-cols-3', (heading || lede) && 'mt-8']}>
    {cards.map((card) => (
      <li>
        <article
          class="grid h-full content-start gap-3 rounded-lg p-6"
          style="background: var(--surface-raised); border: 1px solid var(--border-subtle); box-shadow: var(--elevation-1); background-image: var(--depth-glow-subtle)"
        >
          {card.badge && <span class="badge badge-brand w-fit">{card.badge}</span>}
          <div>
            <h3 class="type-heading-md">{card.name}</h3>
            {card.tagline && (
              <p class="type-body-sm" style={`color: ${accentVar(card.accent)}; font-weight: 600`}>
                {card.tagline}
              </p>
            )}
          </div>
          {card.description && (
            <p class="type-body-sm" style="color: var(--text-secondary)">
              {card.description}
            </p>
          )}
          <ul class="grid gap-1.5">
            {card.features.map((feature) => (
              <li
                class="type-body-sm flex items-start gap-2"
                style="color: var(--text-secondary)"
              >
                <span style="color: var(--data-positive-text)">
                  <Icon name="check" size={16} />
                </span>
                {feature}
              </li>
            ))}
          </ul>
          {card.cta && (
            <a
              href={card.cta.href}
              class="type-body-sm mt-1 font-semibold underline"
              style="color: var(--text-brand)"
            >
              {card.cta.label}
            </a>
          )}
        </article>
      </li>
    ))}
  </ul>
</div>
