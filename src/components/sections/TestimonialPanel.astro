---
/**
 * TestimonialPanel — customer quotes. Static, zero JS. Ratings render as
 * stars with a text equivalent for AT (never icon-only meaning).
 */
import type { TestimonialPanelContent } from '@/types/sections';

type Props = TestimonialPanelContent;
const { heading, lede, testimonials } = Astro.props;
---

<div>
  {heading && <h2 class="type-heading-lg">{heading}</h2>}
  {lede && (
    <p class="type-body-md mt-2 max-w-article" style="color: var(--text-secondary)">
      {lede}
    </p>
  )}
  <ul
    class:list={[
      'grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3',
      (heading || lede) && 'mt-8',
    ]}
  >
    {testimonials.map((item) => (
      <li>
        <figure
          class="grid h-full content-start gap-3 rounded-lg p-6"
          style="background: var(--surface-raised); border: 1px solid var(--border-subtle); box-shadow: var(--elevation-1); background-image: var(--depth-glow-subtle)"
        >
          {item.rating && (
            <p class="type-body-sm" style="color: var(--data-warning-text)">
              <span aria-hidden="true">
                {'★'.repeat(Math.round(item.rating))}{'☆'.repeat(5 - Math.round(item.rating))}
              </span>
              <span class="sr-only">{item.rating} out of 5 stars</span>
            </p>
          )}
          <blockquote class="type-body-md" style="color: var(--text-primary)">
            “{item.quote}”
          </blockquote>
          <figcaption class="type-body-sm" style="color: var(--text-secondary)">
            <span class="font-semibold" style="color: var(--text-primary)">
              {item.author}
            </span>
            {item.role && <span> — {item.role}</span>}
            {item.context && (
              <span class="type-caption block" style="color: var(--text-muted)">
                {item.context}
              </span>
            )}
          </figcaption>
        </figure>
      </li>
    ))}
  </ul>
</div>
