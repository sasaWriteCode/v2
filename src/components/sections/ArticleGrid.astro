---
/**
 * ArticleGrid — article link-cards. Static, zero JS.
 */
import type { ArticleGridContent } from '@/types/sections';

type Props = ArticleGridContent;
const { heading, lede, articles } = Astro.props;
---

<div>
  {heading && <h2 class="type-heading-lg">{heading}</h2>}
  {lede && (
    <p class="type-body-md mt-2 max-w-article" style="color: var(--text-secondary)">
      {lede}
    </p>
  )}
  <ul
    class:list={[
      'grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3',
      (heading || lede) && 'mt-8',
    ]}
  >
    {articles.map((article) => (
      <li>
        <a
          href={article.href}
          class="grid h-full content-start overflow-hidden rounded-lg"
          style="background: var(--surface-raised); border: 1px solid var(--border-subtle); box-shadow: var(--elevation-1); color: inherit; text-decoration: none"
        >
          {article.image && (
            <img
              src={article.image.src}
              alt={article.image.alt}
              width={article.image.width}
              height={article.image.height}
              loading="lazy"
              decoding="async"
              class="w-full object-cover"
              style={`aspect-ratio: ${article.image.width} / ${article.image.height}`}
            />
          )}
          <span class="grid gap-2 p-5">
            {(article.category || article.readTime) && (
              <span class="flex items-center gap-2">
                {article.category && <span class="chip">{article.category}</span>}
                {article.readTime && (
                  <span class="type-caption" style="color: var(--text-muted)">
                    {article.readTime}
                  </span>
                )}
              </span>
            )}
            <span class="type-heading-sm">{article.title}</span>
            {article.description && (
              <span class="type-body-sm" style="color: var(--text-secondary)">
                {article.description}
              </span>
            )}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
