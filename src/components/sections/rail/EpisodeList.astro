---
/**
 * EpisodeList — "Recommended Episodes" rail block. Static link list.
 */
import type { RailEpisode } from '@/types/sections';

interface Props {
  heading: string;
  episodes: RailEpisode[];
}
const { heading, episodes } = Astro.props;
---

<section
  aria-label={heading}
  class="rounded-lg p-5"
  style="background: var(--surface-raised); border: 1px solid var(--border-subtle); box-shadow: var(--elevation-1)"
>
  <h2 class="type-heading-sm">{heading}</h2>
  <ul class="mt-3 grid gap-3">
    {episodes.map((episode) => (
      <li>
        <a href={episode.href} class="grid gap-0.5" style="color: inherit; text-decoration: none">
          {episode.moduleLabel && (
            <span class="type-overline" style="color: var(--text-muted)">
              {episode.moduleLabel}
            </span>
          )}
          <span class="type-body-sm font-semibold" style="color: var(--text-brand)">
            {episode.title}
          </span>
          {episode.duration && (
            <span class="type-caption numeric" style="color: var(--text-muted)">
              {episode.duration}
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>
