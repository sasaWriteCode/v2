---
/**
 * Footer — full IA from src/config/navigation.ts. Static, zero JS. Also the
 * no-JS safety net for the mobile nav (every primary destination repeats
 * here as a plain link).
 */
import { BRAND, FOOTER_LEGAL, FOOTER_NAV, NAV_STRINGS } from '@/config/navigation';
---

<footer data-zone="showroom" style="border-top: 1px solid var(--border-subtle)">
  <div class="container section-y-tight">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,4fr)_minmax(0,8fr)]">
      <div>
        <a href={BRAND.href} class="inline-block" aria-label="IrisPro Home">
          <img
            src="/IP-Logo-White.png"
            alt="IrisPro Logo"
            height="32"
            width="74"
            class="h-8 w-auto object-contain"
          />
        </a>
        <p class="type-body-sm mt-3" style="color: var(--text-secondary)">
          {BRAND.tagline}
        </p>
      </div>
      <nav aria-label={NAV_STRINGS.footerNavLabel}>
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-5">
          {FOOTER_NAV.map((group) => (
            <div>
              <h2 class="type-overline" style="color: var(--text-muted)">
                {group.heading}
              </h2>
              <ul class="mt-3 grid gap-2">
                {group.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="type-body-sm"
                      style="color: var(--text-secondary); text-decoration: none"
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </nav>
    </div>
    <p
      class="type-caption mt-10 pt-6"
      style="color: var(--text-muted); border-top: 1px solid var(--border-subtle)"
    >
      {FOOTER_LEGAL}
    </p>
  </div>
</footer>
