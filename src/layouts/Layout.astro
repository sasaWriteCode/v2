---
/**
 * Base layout — port of the Next.js root layout (metadata, brand fonts,
 * skip-link, main landmark). Pages with no islands ship zero JS.
 */
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'IrisPro — The Best Tint for ASEAN',
  description = 'IrisPro window-film protection technology. V2 foundation — design system and enhancement engine.',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Brand fonts (extracted from V1). Stage 2 may move these to self-
        hosting; runtime <link> keeps Stage 1 builds network-independent. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
