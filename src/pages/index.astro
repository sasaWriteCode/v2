---
/**
 * Home — EditorialTemplate driven by the `editorial/home` content object.
 */
import { getEntry } from 'astro:content';
import EditorialTemplate from '@/templates/EditorialTemplate.astro';

const home = await getEntry('editorial', 'home');
if (!home) throw new Error('editorial/home content object is missing');
---

<EditorialTemplate content={home.data} />
